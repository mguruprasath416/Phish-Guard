# ============================================================
# SERVER CONFIGURATION
# ============================================================
PORT=5000
NODE_ENV=development

# ============================================================
# DATABASE
# ============================================================
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/phishguard?retryWrites=true&w=majority

# ============================================================
# JWT AUTHENTICATION
# ============================================================
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRE=7d

# ============================================================
# EMAIL SERVICE (Gmail)
# ============================================================
EMAIL_SERVICE_HOST=smtp.gmail.com
EMAIL_SERVICE_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password_here

# ============================================================
# GOOGLE OAUTH
# ============================================================
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_google_client_secret

# ============================================================
# FRONTEND URL (update this after Vercel deployment)
# ============================================================
FRONTEND_URL=http://localhost:3000
# In production use: FRONTEND_URL=https://your-app.vercel.app

# ============================================================
# PYTHON AI MICROSERVICES (local development only)
# ============================================================
EMAIL_SERVICE_URL=http://localhost:8001
URL_SERVICE_URL=http://localhost:8002
THREAT_INTEL_URL=http://localhost:8003
LLM_SERVICE_URL=http://localhost:8004
RISK_ENGINE_URL=http://localhost:8005

# ============================================================
# EXTERNAL API KEYS (Optional — replace with your own keys)
# ============================================================
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
GOOGLE_SAFE_BROWSING_API_KEY=your_google_safe_browsing_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# ============================================================
# LLM CONFIGURATION (Optional)
# ============================================================
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your_openai_api_key_here
LLAMA_URL=http://localhost:11434
LLAMA_MODEL=llama2
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-large
